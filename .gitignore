.DS_Store
*.pem

# local env files
.env*.local
# General .env (Expo public vars) — must NEVER be committed.
# Historical commits already contain a populated .env; rotate Supabase keys
# and the GPS proxy creds, then consider rewriting history (git filter-repo).
.env

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
