# GPS Proxy 環境變數範例
# 複製為 .env 並填入實際值；請勿提交實際金鑰

# 32 bytes 的 base64 字串，建議：
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GPS_SESSION_KEY=

#─────────────────────────────────────────────
# GPS Proxy URL（本地開發留空，Vercel 部署需填入）
# 本地開發：前端自動使用 window.location.origin + :3001/api/gps
# Vercel 部署：填入部署到 Railway/Render 等平台的 Proxy URL
# 例如：https://my-gps-proxy.up.railway.app/api/gps
EXPO_PUBLIC_GPS_PROXY_URL=
