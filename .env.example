# FleetPro Web Environment Variables
# Copy this file to .env and fill in your local values.
# NEVER commit .env with real secrets. Use Vercel Project Settings or
# GitHub Actions secrets to inject EXPO_PUBLIC_* values at build time.

# Supabase project URL (no trailing slash)
EXPO_PUBLIC_SUPABASE_URL=

# Supabase publishable (anon) key — safe to ship to client
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Proxy / server URL that the 808 GPS API requests will be routed through.
# In web builds, gps808Api will rewrite direct 808GPS calls to go through this proxy.
EXPO_PUBLIC_GPS_PROXY_URL=
